{
  "name": "socialbuffer",
  "version": "0.1.0",
  "description": "Queue markdown-based social posts to Buffer for X and LinkedIn from the terminal.",
  "type": "module",
  "bin": {
    "socialbuffer": "./bin/tweetx.js",
    "tweetx": "./bin/tweetx.js"
  },
  "files": [
    "bin",
    "README.md"
  ],
  "scripts": {
    "start": "node ./bin/tweetx.js",
    "check": "node ./bin/tweetx.js --help",
    "check:dry-run": "node ./bin/tweetx.js post --file ./example-post.md --dry-run",
    "test": "npm run check && npm run check:dry-run"
  },
  "keywords": [
    "buffer",
    "social",
    "social-media",
    "x",
    "twitter",
    "linkedin",
    "cli",
    "markdown"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
